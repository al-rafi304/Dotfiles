{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "control-center-width": 350,
  "control-center-height": 1000,
  "notification-window-width": 300,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "buttons-grid",
    "volume",
    "slider#mic",
    "title",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear  ó°ŽŸ"
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "label": {
      "max-lines": 1,
      "text": "Control Center"
    },
    "mpris": {
        "autohide": true
    },
    "volume": {
      "label": "ó°•¾",
        "show-per-app": true
    },
    "slider#mic": {
      "label": "ï„°",
      "max": 120,
      "min": 0,
      "max_limit": 120,
      "min_limit": 0,
      "cmd_getter": "pactl get-source-volume @DEFAULT_SOURCE@ | grep -o '[0-9]*%' | head -n 1 | tr -d '%'",
      "cmd_setter": "pactl set-source-volume @DEFAULT_SOURCE@ $value%"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "ï‘¦ ",
          "type": "toggle",
          "active": true,
          "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
          "update-command": "pactl get-sink-mute @DEFAULT_SINK@ | grep yes && echo true || echo false"
        },
        {
          "label": "ï„± ",
          "type": "toggle",
          "active": false,
          "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
          "update-command": "pactl get-source-mute @DEFAULT_SOURCE@ | grep yes && echo true || echo false"
        },
        {
          "label": "ó°ª“",
          "type": "toggle",
          "active": true,
          "command": "swaync-client -d",
          "update-command": "swaync-client -D"
        },
        {
          "label": "ó°»œ ",
          "command": "swaync-client -cp && ~/.config/myscripts/screenshot.sh"
        }
        
      ]
    }
  }
}